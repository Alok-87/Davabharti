{
  "name": "davabharti-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "npm run update:version && next build --turbopack",
    "start": "next start",
    "lint": "echo 'Skipping lint for now... ✅'",
    "format": "prettier --write .",
    "update:version": "node ./scripts/update-version.js",
    "version:major": "npm version major -m \"v%s: Major release 🚀\"",
    "version:minor": "npm version minor -m \"v%s: Minor improvements ✨\"",
    "version:bugfix": "npm version patch -m \"v%s: Bug fixes 🐞\"",
    "version:release": "npm version prerelease --preid=beta -m \"v%s: Pre-release build 🧪\"",
    "postversion": "npm run build && git add . && git commit -am \"chore: build for v$(node -p \\\"require('./package.json').version\\\")\" && git push && git push --tags && echo Build complete."
  },
  "dependencies": {
